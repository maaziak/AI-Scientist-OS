# App
APP_ENV=development
APP_NAME="AI Scientist OS"
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
JWT_SECRET=change-me

# LLM / Ollama
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_OPENAI_BASE_URL=http://localhost:11434/v1
OLLAMA_CHAT_MODEL=gpt-oss:120b-cloud
OLLAMA_FALLBACK_CHAT_MODEL=deepseek-v3.1:671b-cloud
OLLAMA_EMBED_MODEL=
OLLAMA_FALLBACK_EMBED_MODEL=
OLLAMA_API_KEY=ollama

# OpenAI SDK compatibility only; do not call OpenAI hosted models
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama

# Search
SERPAPI_API_KEY=
SERPAPI_BASE_URL=https://serpapi.com/search.json

# NCBI / PubMed URL access
NCBI_EUTILS_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
NCBI_TOOL=ai-scientist-os
NCBI_EMAIL=
NCBI_API_KEY=

# Semantic Scholar URL search via SerpAPI
SEMANTIC_SCHOLAR_SITE=https://www.semanticscholar.org

# PubChem
PUBCHEM_PUG_REST_BASE_URL=https://pubchem.ncbi.nlm.nih.gov/rest/pug

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/ai_scientist_os
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/ai_scientist_os

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage
LOCAL_STORAGE_PATH=./storage

# Rate limits
NCBI_MAX_RPS_WITHOUT_KEY=3
SERPAPI_MAX_RPS=1
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3

# Safety
ENABLE_SAFETY_GUARDRAILS=true
MAX_PROTOCOL_RISK_LEVEL=medium

# Workflow
WORKFLOW_EAGER=false
RQ_QUEUE_NAME=ai_scientist_os
EMBEDDING_DIMENSION=768
