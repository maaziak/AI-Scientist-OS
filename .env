LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_OPENAI_BASE_URL=http://localhost:11434/v1
OLLAMA_CHAT_MODEL=gpt-oss:120b-cloud
OLLAMA_FALLBACK_CHAT_MODEL=deepseek-v3.1:671b-cloud
OLLAMA_EMBED_MODEL=
OLLAMA_FALLBACK_EMBED_MODEL=
OLLAMA_API_KEY=ollama

OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama

SERPAPI_API_KEY=7a3367726cedb68cb9a65192c24dadde5148a86ae79b5392b4a85bcecde66f23
SERPAPI_BASE_URL=https://serpapi.com/search.json

NCBI_EUTILS_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
NCBI_TOOL=ai-scientist-os
NCBI_EMAIL=
NCBI_API_KEY=

SEMANTIC_SCHOLAR_SITE=https://www.semanticscholar.org

PUBCHEM_PUG_REST_BASE_URL=https://pubchem.ncbi.nlm.nih.gov/rest/pug

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/ai_scientist_os
