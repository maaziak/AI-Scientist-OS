HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3

ENABLE_SAFETY_GUARDRAILS=true
MAX_PROTOCOL_RISK_LEVEL=medium

WORKFLOW_EAGER=false
